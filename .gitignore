# Python
.venv/
api/.venv/
__pycache__/
api/__pycache__/
api/*.pyc
api/.env
api/.env.*.local

# Curl/test session artifacts (may contain tokens)
*cookies*.txt

# Node
ui/node_modules/
ui/.vite/
ui/dist/
ui/.env
ui/.env.local
ui/.env.*.local
api/node_modules/
node_modules/

# OS/editor junk
.DS_Store
*.log

# iOS/Xcode
ui/ios/App/Pods/
ui/ios/App/*.xcworkspace/xcuserdata/
ui/ios/App/*.xcodeproj/xcuserdata/
ui/ios/App/build/
ui/ios/App/DerivedData/
*.xcuserstate
*.xcuserdatad

# SQLite databases (contains user data - should not be committed)
*.db
*.sqlite
*.sqlite3
