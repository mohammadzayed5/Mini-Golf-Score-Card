{
	"appId": "com.MohammadZayed.minigolf",
	"appName": "Mini Golf Score Card",
	"webDir": "dist",
	"bundledWebRuntime": false,
	"plugins": {
		"AdMob": {
			"appId": "ca-app-pub-5108646735858325~1799492394",
			"testingDevices": [
				"YOUR_DEVICE_ID_HERE"
			]
		},
		"SplashScreen": {
			"launchShowDuration": 800,
			"launchAutoHide": true,
			"backgroundColor": "#ffffff",
			"androidSplashResourceName": "splash",
			"iosSpinnerStyle": "small",
			"showSpinner": false,
			"splashFullScreen": true,
			"splashImmersive": true
		}
	},
	"packageClassList": [
		"AdMobPlugin",
		"PreferencesPlugin",
		"SplashScreenPlugin"
	]
}
